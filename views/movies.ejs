<%- include('./partials/head.ejs') %>

<main id="main-content">
	<% if (hero.length) { %>
	<section class="hero" aria-label="Featured movies">
		<% hero.forEach(function(movie, i) { %>
		<div class="hero-slide<%= i === 0 ? ' active' : '' %>" role="group" aria-roledescription="slide" aria-label="Slide <%= i + 1 %> of <%= hero.length %>">
			<img class="hero-backdrop" src="https://image.tmdb.org/t/p/original/<%= movie.backdrop_path %>" alt="">
			<div class="hero-overlay"></div>
			<div class="hero-content">
				<h2 class="hero-title"><%= movie.title %></h2>
				<div class="hero-genres">
					<% movie.genreNames.forEach(function(g) { %>
					<span class="hero-genre-tag"><%= g %></span>
					<% }) %>
				</div>
				<div class="hero-rating">
					<i class="fa-solid fa-star star" aria-hidden="true"></i>
					<span class="score"><%= movie.vote_average.toFixed(1) %></span>
					<span>/ 10</span>
				</div>
				<p class="hero-overview"><%= movie.overview %></p>
				<div class="hero-actions">
					<a href="/movies/<%= movie.id %>" class="btn btn-primary">
						<i class="fa-solid fa-circle-info" aria-hidden="true"></i> More Info
					</a>
				</div>
			</div>
		</div>
		<% }) %>
		<div class="hero-indicators" role="tablist" aria-label="Hero slide indicators">
			<% hero.forEach(function(movie, i) { %>
			<button class="hero-dot<%= i === 0 ? ' active' : '' %>" role="tab" aria-selected="<%= i === 0 %>" aria-label="Slide <%= i + 1 %>: <%= movie.title %>" data-slide="<%= i %>"></button>
			<% }) %>
		</div>
	</section>
	<% } %>
	<% var rows = [
		{ title: "Trending This Week", key: "trending", icon: "fa-fire" },
		{ title: "Popular", key: "popular", icon: "fa-chart-line" },
		{ title: "Top Rated", key: "topRated", icon: "fa-trophy" },
		{ title: "Now Playing", key: "nowPlaying", icon: "fa-clapperboard" },
		{ title: "Upcoming", key: "upcoming", icon: "fa-calendar" }
	]; %>
	<% rows.forEach(function(row) { %>
	<% var movies = moviesData[row.key]; %>
	<% if (movies && movies.length) { %>
	<section class="section" aria-label="<%= row.title %>">
		<div class="section-header has-padding">
			<h2 class="section-title"><span class="accent-bar"></span><%= row.title %></h2>
		</div>
		<div class="movie-row">
			<% movies.forEach(function(movie) { %>
			<a href="/movies/<%= movie.id %>" class="movie-card" data-movie-id="<%= movie.id %>" aria-label="<%= movie.title %>">
				<% if (movie.poster_path) { %>
				<img class="poster" src="https://image.tmdb.org/t/p/w342/<%= movie.poster_path %>" alt="Poster of <%= movie.title %>" loading="lazy">
				<% } else { %>
				<div class="poster no-poster" aria-label="No poster available"><i class="fa-solid fa-film" aria-hidden="true"></i></div>
				<% } %>
				<div class="card-info">
					<div class="card-title"><%= movie.title %></div>
					<div class="card-meta">
						<span class="card-date"><%= movie.release_date ? movie.release_date.substring(0, 4) : '' %></span>
						<span class="card-rating"><%= movie.vote_average ? movie.vote_average.toFixed(1) : 'N/A' %></span>
					</div>
				</div>
			</a>
			<% }) %>
		</div>
	</section>
	<% } %>
	<% }) %>
</main>

<%- include('./partials/footer.ejs') %>
